{
  "name": "Java 21 Dev Environment",

  "image": "mcr.microsoft.com/devcontainers/java:21",

  "features": {
    "ghcr.io/devcontainers/features/maven:1": {}
  },

  "postCreateCommand": "mkdir -p ~/.m2 && cp .devcontainer/settings.xml ~/.m2/settings.xml",

  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vscjava.vscode-maven"
      ]
    }
  }
}
